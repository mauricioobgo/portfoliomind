# PortfolioMind v4 - environment variables
#
# Copy this file to ".env" and fill in real values, OR put the same keys in
# ~/.hermes/profiles/builder/.env. The config loader reads the profile env
# first, then the project .env, then the process env (later sources win).
#
# = InvestingPro (used by card 2) =
# Login for the InvestingPro account that the agent scrapes.
INVESTINGPRO_EMAIL=your-email-here
INVESTINGPRO_PASSWORD=your-password-here

# = XTB xStation (used by card 3) =
# xStation 5 login credentials. The user is fully responsible for the safety
# of these - never commit them, never log them, never echo them in errors.
XTB_USER_ID=your-xtb-user-id
XTB_PASSWORD=your-xtb-password

# = Google Sheets (used by card 1 - this card) =
# Either an absolute path to the service account JSON file OR the raw JSON
# contents inline. Path is the recommended form.
#
#   Path form: /absolute/path/to/service-account.json
#   Inline form: {"type":"service_account","project_id":"...", ...}
#
# The service account MUST be granted Editor access to the Google Sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
# Sheet ID is the long alphanumeric token in the sheet URL between /d/ and /edit.
# Leave blank to have the bootstrap script create a new sheet on first run.
GOOGLE_SHEET_ID=

# = LLM (used by future strategy / narrative cards) =
# OpenAI API key. Validated by config but NOT exercised in card 1.
OPENAI_API_KEY=your-openai-key

# = Optional =
# Where to persist Playwright Chromium cookies between runs.
# Default: ./sessions (relative to wherever the script is invoked from)
SESSION_DIR=./sessions

# Where to save pre-trade screenshots.
# Default: ./screenshots
SCREENSHOT_DIR=./screenshots
